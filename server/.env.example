PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/formforge
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173

# --- AI features (question generation, paste parser, grammar fix, duplicate detection, response summaries) ---
# Pick which provider powers the AI endpoints by default. You only need to fill in the
# key for the provider you choose — the other section can stay blank.
AI_PROVIDER=anthropic
# AI_MODEL overrides the default model for whichever provider you picked above.
# Leave blank to use the provider's default (claude-sonnet-4-5, or gemini-2.5-flash).
# Valid values: claude-sonnet-4-5 | claude-haiku-4-5 | gemini-2.5-flash | gemini-3.5-flash
AI_MODEL=

# Claude (Anthropic) — get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Gemini (Google) — get a free key at https://aistudio.google.com/apikey
# Both gemini-2.5-flash (fast/cheap) and gemini-3.5-flash (stronger reasoning) work with the same key —
# pick between them per-request from the AI panel in the UI, or set AI_MODEL above to lock one in.
GEMINI_API_KEY=

# --- Email verification ---
# Leave blank during local dev: verification links are logged to the server console instead of emailed.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="FormForge <no-reply@yourdomain.com>"

# --- Google login ---
# Create an OAuth client at https://console.cloud.google.com/apis/credentials — leave blank to disable
GOOGLE_CLIENT_ID=
